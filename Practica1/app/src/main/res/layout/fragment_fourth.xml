<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollView4"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8EAF6"
    android:fillViewport="true"
    tools:context=".FourthFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/imgAlu"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerInside"
            android:padding="16dp"
            android:background="@android:color/white"
            android:elevation="4dp"
            android:layout_marginBottom="20dp"
            android:src="@drawable/alu" />

        <TextView
            android:id="@+id/tituloDefAlu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:text="¿Qué es la ALU?" />

        <TextView
            android:id="@+id/defAlu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:padding="20dp"
            android:elevation="3dp"
            android:layout_marginBottom="24dp"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp"
            android:textColor="#37474F"
            android:justificationMode="inter_word"
            android:text="La Unidad Aritmético-Lógica (ALU) es el verdadero cerebro matemático de la computadora. Es el circuito digital que calcula operaciones aritméticas (como sumas y restas) y operaciones lógicas (como AND, OR, XOR) entre valores binarios." />

        <TextView
            android:id="@+id/codeVHDL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="#263238"
            android:textColor="#4CAF50"
            android:padding="18dp"
            android:elevation="4dp"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"
            android:text="-- Compuerta AND en VHDL\nentity AND_GATE is\n  Port ( A, B : in STD_LOGIC;\n         Y : out STD_LOGIC);\nend AND_GATE;\n\narchitecture Logica of AND_GATE is\nbegin\n  Y &lt;= A and B;\nend Logica;" />

        <TextView
            android:id="@+id/tituloCuriosidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:text="💡 Fun Fact: Escala Nanométrica" />

        <TextView
            android:id="@+id/funFactAlu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:padding="20dp"
            android:elevation="3dp"
            android:layout_marginBottom="24dp"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp"
            android:textColor="#37474F"
            android:justificationMode="inter_word"
            android:text="Toda esta magia lógica se logra gracias a los transistores. Procesadores modernos como el Ryzen 5 5600X están fabricados con una arquitectura de 7nm. Esto permite empaquetar alrededor de 4 mil millones de transistores microscópicos en un solo chip para formar todas las compuertas lógicas y flip-flops necesarios." />

        <ImageView
            android:id="@+id/imgCPU"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerInside"
            android:padding="16dp"
            android:background="@android:color/white"
            android:elevation="4dp"
            android:layout_marginBottom="28dp"
            android:src="@drawable/cpu" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Volver"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#5C72B8"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegresar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Ir al menú"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#5C72B8"
                app:cornerRadius="28dp"
                app:elevation="4dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>